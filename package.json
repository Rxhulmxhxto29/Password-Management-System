{
  "name": "secure-vault-desktop",
  "version": "1.0.0",
  "description": "Zero-knowledge password manager",
  "main": "main.js",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm start --prefix backend\" \"npm run dev --prefix frontend\" \"wait-on http://localhost:3000 && electron .\"",
    "build": "npm run build --prefix frontend && electron-builder --win",
    "web:dev": "concurrently \"npm start --prefix backend\" \"npm run dev --prefix frontend\""
  },
  "build": {
    "appId": "com.secure.vault",
    "productName": "Secure Vault",
    "directories": { "output": "dist-desktop" },
    "win": { "target": ["nsis", "portable"] },
    "mac": { "target": "dmg" },
    "files": ["main.js", "backend/**/*", "frontend/dist/**/*", "package.json"],
    "asar": true
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^31.0.0",
    "electron-builder": "^25.1.8",
    "electron-is-dev": "^3.0.1",
    "wait-on": "^9.0.4"
  }
}
